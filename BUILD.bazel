load("@rules_wasm_component//rust:defs.bzl", "rust_wasm_component_bindgen")
load("@rules_wasm_component//wit:defs.bzl", "wit_library")

package(default_visibility = ["//visibility:public"])

# ═══════════════════════════════════════════════════════════════
# Water Leak Detector
# ═══════════════════════════════════════════════════════════════

wit_library(
    name = "wohl_leak_wit",
    srcs = ["crates/wohl-leak/wit/leak.wit"],
    package_name = "pulseengine:wohl-leak",
    world = "wohl-leak",
)

rust_wasm_component_bindgen(
    name = "wohl-leak",
    srcs = ["crates/wohl-leak/src/wasm_component.rs"],
    wit = ":wohl_leak_wit",
    wasi_version = "p3",
    profiles = ["release"],
)

