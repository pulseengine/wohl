# OS
.DS_Store
Thumbs.db

# Verus produces a binary next to each input file when invoked as
# `verus proofs/verus/<name>.rs` (default `--compile` behaviour).
/alert_dedup
/proofs/verus/alert_dedup


# Rivet external project cache + machine-local external pin. The `relay`
# external is resolved live (CI checks out relay@main as a sibling);
# rivet.lock would pin a machine-local commit CI cannot match, so it is
# regenerated locally (`rivet lock`), not committed.
.rivet/
rivet.lock

# Claude Code machine-local settings (e.g. env.TMPDIR → /Volumes/devcache);
# machine-specific, must not be committed. settings.json (shared) is fine.
.claude/settings.local.json
.claude/worktrees/
